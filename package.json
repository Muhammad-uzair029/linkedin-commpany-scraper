{
  "name": "linkedin-people-scraper",
  "version": "1.0.0",
  "description": "LinkedIn company People page scraper (session cookie + Puppeteer)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "scrape": "node index.js",
    "open-session": "node open-session.js",
    "login": "node open-session.js --profile",
    "scrape:profile": "node index.js --profile",
    "scrape:2": "node index.js --profile --max 2 --format json",
    "scrape:50": "node index.js --profile --max 50 --batch-size 50 --parallel-tabs 8 --format json",
    "scrape:simple": "node index.js --profile --max 50 --batch-size 50 --parallel-tabs 2 --format json",
    "scrape:debug": "node index.js --profile --max 10 --batch-size 10 --parallel-tabs 1 --headed --format json",
    "scrape:200": "node index.js --profile --max 200 --batch-size 200 --parallel-tabs 8 --format json",
    "scrape:600": "node index.js --profile --max 600 --batch-size 0 --parallel-tabs 8 --format json",
    "scrape:all": "node index.js --profile --max 2518 --batch-size 0 --parallel-tabs 8 --format json",
    "scrape:stealth": "node index.js --profile --max 2518 --batch-size 100 --parallel-tabs 1 --format json",
    "postinstall": "npx puppeteer browsers install chrome",
    "install-browser": "npx puppeteer browsers install chrome"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "puppeteer": "^24.2.0"
  }
}
